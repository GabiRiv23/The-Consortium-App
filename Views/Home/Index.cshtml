@{
    ViewData["Title"] = "Tablero Principal";
}

<div class="container mt-4">

    <video class="position-absolute top-50 start-50 translate-middle w-100 h-100" style="object-fit: cover; opacity: 0.25; z-index: 1;" autoplay loop muted playsinline>
        <source src="~/videos/consorcio-bg.mp4" type="video/mp4" />
        Tu navegador no soporta video.
    </video>

    <div class="container position-relative p-5" style="z-index: 2;">
        <h1 class="display-3 fw-bold mb-3 text-white">The Consortium App</h1>
    </div>
        </h1>
        <p class="lead fw-normal text-light mb-4 fs-4 mx-auto" style="max-width: 650px;">
            La solución definitiva, privada y escalable para la administración integral de consorcios, liquidación de expensas y control de gastos.
        </p>
    </div>

    <!--  KPI CARDS -->
    <div class="row g-3 mb-4 text-center">

        <div class="col-md-3">
            <div class="card bg-primary text-white shadow-sm">
                <div class="card-body">
                    <h6 class="mb-1">Consorcios</h6>
                    <h2 class="fw-bold">@ViewBag.TotalConsorcios</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white shadow-sm">
                <div class="card-body">
                    <h6 class="mb-1">Unidades</h6>
                    <h2 class="fw-bold">@ViewBag.TotalUnidades</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-dark shadow-sm">
                <div class="card-body">
                    <h6 class="mb-1">Activas</h6>
                    <h2 class="fw-bold">@ViewBag.UnidadesActivas</h2>
                </div>
            </div>
        </div>

                </div>
            </div>
        </div>

    </div>

                    <div class="d-grid">
                        <a asp-controller="Consorcio" asp-action="Index" class="btn btn-outline-primary">
                            Ir a Consorcios
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <h5 class="fw-bold text-success">Unidades Funcionales</h5>
                        <p class="text-muted mb-3">
                            Visualiza y administra departamentos, propietarios y coeficientes.
                        </p>
                    </div>

