@model IEnumerable<TheConsortiumApp.Models.Gasto>

@{
    ViewData["Title"] = "Gastos";
}

<h2>Gastos</h2>

<form method="get" class="row mb-3">
    <div class="col-md-4">
        <label>Consorcio</label>
        <select name="consorcioId" class="form-control">
            <option value="0">Todos los consorcios</option>

                @foreach (var c in ViewBag.Consorcios)
                {
                    if (c.Id == ViewBag.ConsorcioIdSeleccionado)
                    {
                        <option value="@c.Id" selected>@c.Nombre</option>
                    }
                    else
                    {
                        <option value="@c.Id">@c.Nombre</option>
                    }
                }
        </select>
    </div>

    <div class="col-md-3">
        <label>Año</label>
        <input type="number" name="year" value="@ViewBag.Year" class="form-control" />
    </div>

    <div class="col-md-3">
        <label>Mes</label>
        <input type="number" name="month" value="@ViewBag.Month" class="form-control" min="1" max="12" />
    </div>

    <div class="col-md-2 d-flex align-items-end">
        <button class="btn btn-success w-100">Filtrar</button>
    </div>

<div class="d-flex gap-2 mb-3">
    <a asp-action="Create" class="btn btn-primary">
        + Nuevo Gasto
    </a>

    <a class="btn btn-outline-danger"
       asp-action="ExportPdf"
       asp-route-consorcioId="@ViewBag.ConsorcioIdSeleccionado"
       asp-route-year="@ViewBag.Year"
       asp-route-month="@ViewBag.Month">
        Exportar PDF
    </a>
</div>

<div class="alert alert-info">

<!-- ✅ TABLA -->
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Concepto</th>
            <th>Monto</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var g in Model)
            {
                <tr>
                    <td>@g.Concepto</td>
                    <td>$@g.Monto</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center">No hay gastos para los filtros seleccionados.</td>
            </tr>
        }
    </tbody>
</table>