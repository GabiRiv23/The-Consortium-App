@model IEnumerable<TheConsortiumApp.Models.UnidadFuncional>

<h2>Unidades Funcionales</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    + Nueva Unidad
</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Unidad</th>
            <th>Piso / Depto</th>
            <th>Coeficiente</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.NroUnidad</td>
                <td>@u.PisoDepto</td>
                <td>@u.Coeficiente</td>
            </tr>
        }
    </tbody>
</table>